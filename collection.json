              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"boards\": [\n    {\"id\": \"uuid1\", \"position\": 1},\n    {\"id\": \"uuid2\", \"position\": 2}\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/boards/reorder",
              "host": ["{{baseUrl}}"],
              "path": ["boards", "reorder"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Reorder response has JSON\", function () {",
                  "    pm.response.to.be.json;",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.be.an('array').or.to.be.an('object');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "token",
      "value": "your-jwt-token-here"
    }
  ]
}